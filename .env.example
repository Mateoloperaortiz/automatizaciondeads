# Database
DATABASE_URL="postgresql://username:password@localhost:5432/adsmaster"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key"

# Meta (Facebook) API
META_CLIENT_ID="your-meta-client-id"
META_CLIENT_SECRET="your-meta-client-secret"

# Google Ads API
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Twitter (X) API
TWITTER_CLIENT_ID="your-twitter-client-id"
TWITTER_CLIENT_SECRET="your-twitter-client-secret"

# TikTok API
TIKTOK_CLIENT_ID="your-tiktok-client-id"
TIKTOK_CLIENT_SECRET="your-tiktok-client-secret"

# ATS API
ATS_API_URL="https://ats.magneto.com/api"
ATS_API_KEY="your-ats-api-key"
